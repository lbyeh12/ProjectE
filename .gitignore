# ============================================================
# .gitignore
# 원본/가공 데이터, 비밀정보, 가상환경, 빌드 산출물 등
# 공개 저장소에 올리면 안 되는 파일을 제외한다.
# ============================================================

# --------------------------------------------------------------
# 데이터 (원본 CSV + 전처리/합성 결과물)
# 용량이 크고(events.csv 약 233MB), 실제 고객 데이터(CustomerID, 거래내역)가
# 포함되어 있어 공개 저장소에는 올리지 않는다.
# 필요 시 README에 다운로드 경로/재생성 방법만 안내한다.
# --------------------------------------------------------------
ecommerce_data.csv
*.csv
dataset

# 참고: gitignore는 상위 디렉토리가 제외되면 그 안의 파일을 다시 포함시킬 수 없다.
# 샘플 데이터를 예시로 공개하고 싶다면 위 패턴에 걸리지 않는 별도 경로
# (예: docs/sample-data/) 에 두는 것을 권장한다.

# --------------------------------------------------------------
# 비밀정보 / 환경변수
# DB 접속정보, API 키, JWT 시크릿 등이 들어가는 파일
# --------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*credentials*.json
secrets/

# --------------------------------------------------------------
# Python
# --------------------------------------------------------------
venv-app/
venv-spark/
venv-airflow/
venv-test/
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --------------------------------------------------------------
# Node / React (frontend)
# --------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.env*
!frontend/.env.example
npm-debug.log*
yarn-error.log*

# --------------------------------------------------------------
# Docker / 컨테이너 볼륨 데이터
# 컨테이너 재시작 시 다시 생성되는 데이터이므로 커밋 불필요
# --------------------------------------------------------------
postgres-data/
kafka-data/
zookeeper-data/
docker-volumes/

# --------------------------------------------------------------
# Airflow
# airflow.cfg, airflow.db 에는 로컬 메타데이터/시크릿이 들어갈 수 있음
# --------------------------------------------------------------
airflow/logs/
airflow/airflow.db
airflow/airflow.cfg
airflow/webserver_config.py

# --------------------------------------------------------------
# Spark
# --------------------------------------------------------------
spark-warehouse/
metastore_db/
derby.log

# --------------------------------------------------------------
# Kubernetes (로컬 전용 설정, 시크릿이 들어간 manifest)
# --------------------------------------------------------------
k8s/**/secret*.yaml
kubeconfig*

# --------------------------------------------------------------
# IDE / OS
# --------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# --------------------------------------------------------------
# 로그 / 임시 파일
# --------------------------------------------------------------
*.log
*.tmp
.ipynb_checkpoints/
